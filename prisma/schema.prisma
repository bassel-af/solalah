generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// Users — mirrors auth.users, created on sign-up via GoTrue webhook/trigger
// =============================================================================

model User {
  id         String   @id @db.Uuid // same UUID as auth.users.id
  email      String   @unique
  displayName String  @map("display_name")
  avatarUrl  String?  @map("avatar_url")
  phone      String?
  calendarPreference String @default("hijri") @map("calendar_preference")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  workspaceMemberships WorkspaceMembership[]
  createdWorkspaces    Workspace[]           @relation("WorkspaceCreator")
  sentWorkspaceInvites WorkspaceInvitation[] @relation("InviteSender")
  userTreeLinks        UserTreeLink[]        @relation("TreeLinkUser")
  requestedTreeLinks   UserTreeLink[]        @relation("TreeLinkRequester")
  treeEdits            TreeEditLog[]
  posts                Post[]
  albums               Album[]
  events               Event[]
  eventRsvps           EventRsvp[]
  notifications        Notification[]
  createdIndividuals   Individual[]          @relation("IndividualCreator")
  uploadedMedia        AlbumMedia[]
  createdShareTokens   BranchShareToken[]
  createdPointers      BranchPointer[]

  @@map("users")
}

// =============================================================================
// Workspaces
// =============================================================================

enum BranchSharingPolicy {
  shareable
  copyable_only
  none
}

model Workspace {
  id                   String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug                 String               @unique
  nameAr               String               @map("name_ar")
  logoUrl              String?              @map("logo_url")
  description          String?
  createdById          String               @map("created_by") @db.Uuid
  storageQuotaBytes    BigInt               @default(5368709120) @map("storage_quota_bytes") // 5 GB
  branchSharingPolicy  BranchSharingPolicy  @default(shareable) @map("branch_sharing_policy")
  enableUmmWalad       Boolean              @default(false) @map("enable_umm_walad")
  enableRadaa          Boolean              @default(false) @map("enable_radaa")
  enableKunya          Boolean              @default(false) @map("enable_kunya")
  enableAuditLog       Boolean              @default(false) @map("enable_audit_log")
  enableVersionControl Boolean              @default(false) @map("enable_version_control")
  enableTreeExport     Boolean              @default(true)  @map("enable_tree_export")
  allowMemberExport    Boolean              @default(false) @map("allow_member_export")
  hideBirthDateForFemale Boolean             @default(false) @map("hide_birth_date_for_female")
  hideBirthDateForMale   Boolean             @default(false) @map("hide_birth_date_for_male")
  // Phase 10b: per-workspace data encryption key, wrapped with WORKSPACE_MASTER_KEY.
  // Nullable so existing workspaces can be migrated in a second pass by the migration script.
  encryptedKey         Bytes?               @map("encrypted_key")
  createdAt            DateTime             @default(now()) @map("created_at")

  // Relations
  createdBy               User                  @relation("WorkspaceCreator", fields: [createdById], references: [id])
  memberships             WorkspaceMembership[]
  invitations             WorkspaceInvitation[]
  familyTree              FamilyTree?
  posts                   Post[]
  albums                  Album[]
  events                  Event[]
  userTreeLinks           UserTreeLink[]
  places                  Place[]
  outgoingShareTokens     BranchShareToken[]    @relation("ShareTokenSource")
  targetedShareTokens     BranchShareToken[]    @relation("ShareTokenTarget")
  outgoingPointers        BranchPointer[]       @relation("PointerSource")
  incomingPointers        BranchPointer[]       @relation("PointerTarget")
  adminAccessLogs         AdminAccessLog[]

  @@map("workspaces")
}

// =============================================================================
// Workspace Membership
// =============================================================================

enum WorkspaceRole {
  workspace_admin
  workspace_member
}

enum ContentPermission {
  tree_editor
  news_editor
  album_editor
  event_editor
}

model WorkspaceMembership {
  userId      String              @map("user_id") @db.Uuid
  workspaceId String              @map("workspace_id") @db.Uuid
  role        WorkspaceRole       @default(workspace_member)
  permissions ContentPermission[] @default([])
  joinedAt    DateTime            @default(now()) @map("joined_at")

  // Relations
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@id([userId, workspaceId])
  @@map("workspace_memberships")
}

// =============================================================================
// Workspace Invitations (email + join code)
// =============================================================================

enum InvitationType {
  email
  code
}

enum InvitationStatus {
  pending
  accepted
  revoked
}

model WorkspaceInvitation {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId  String           @map("workspace_id") @db.Uuid
  type         InvitationType
  email        String?          // set for email type
  code         String?          // set for code type (e.g., "SAEED-4X7K")
  individualId String?          @map("individual_id") @db.Uuid // Flow A: invite-with-tree-link
  invitedById  String           @map("invited_by") @db.Uuid
  expiresAt    DateTime?        @map("expires_at")
  maxUses      Int?             @map("max_uses")
  useCount     Int              @default(0) @map("use_count")
  status       InvitationStatus @default(pending)
  createdAt    DateTime         @default(now()) @map("created_at")

  // Relations
  workspace  Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy  User       @relation("InviteSender", fields: [invitedById], references: [id])
  individual Individual? @relation(fields: [individualId], references: [id])

  @@index([code])
  @@index([workspaceId, status])
  @@map("workspace_invitations")
}


// =============================================================================
// User–Tree Linking
// =============================================================================

enum TreeLinkStatus {
  pending
  confirmed
}

model UserTreeLink {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String         @map("user_id") @db.Uuid
  individualId String         @map("individual_id") @db.Uuid
  workspaceId  String         @map("workspace_id") @db.Uuid
  status       TreeLinkStatus @default(pending)
  requestedById String        @map("requested_by") @db.Uuid
  confirmedAt  DateTime?      @map("confirmed_at")

  // Relations
  user        User       @relation("TreeLinkUser", fields: [userId], references: [id], onDelete: Cascade)
  individual  Individual @relation(fields: [individualId], references: [id])
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  requestedBy User       @relation("TreeLinkRequester", fields: [requestedById], references: [id])

  @@unique([userId, workspaceId]) // one link per user per workspace
  @@unique([individualId, workspaceId]) // one link per individual per workspace
  @@map("user_tree_links")
}

// =============================================================================
// Family Tree
// =============================================================================

model FamilyTree {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId    String   @unique @map("workspace_id") @db.Uuid
  lastModifiedAt DateTime @default(now()) @map("last_modified_at")

  // Relations
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  individuals  Individual[]
  families     Family[]
  radaFamilies RadaFamily[]
  editLogs     TreeEditLog[]

  @@map("family_trees")
}

model Individual {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  treeId      String   @map("tree_id") @db.Uuid
  gedcomId    String?  @map("gedcom_id") // original GEDCOM ID if imported
  // Phase 10b: all fields below are AES-256-GCM ciphertext (nonce || tag || data)
  // produced by src/lib/tree/encryption.ts using the workspace's data key.
  givenName   Bytes?   @map("given_name")
  surname     Bytes?
  fullName    Bytes?   @map("full_name")
  sex         String?  // M, F, or null — plaintext: needed for gender validation, tree layout
  birthDate   Bytes?   @map("birth_date")
  birthPlace  Bytes?   @map("birth_place")
  birthPlaceId String? @map("birth_place_id") @db.Uuid
  birthDescription Bytes? @map("birth_description")
  birthNotes  Bytes?   @map("birth_notes")
  deathDate   Bytes?   @map("death_date")
  deathPlace  Bytes?   @map("death_place")
  deathPlaceId String? @map("death_place_id") @db.Uuid
  deathDescription Bytes? @map("death_description")
  deathNotes  Bytes?   @map("death_notes")
  birthHijriDate Bytes? @map("birth_hijri_date")
  kunya       Bytes?
  notes       Bytes?
  deathHijriDate Bytes? @map("death_hijri_date")
  isDeceased  Boolean  @default(false) @map("is_deceased")
  isPrivate   Boolean  @default(false) @map("is_private")
  createdById String?  @map("created_by") @db.Uuid
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  tree               FamilyTree           @relation(fields: [treeId], references: [id], onDelete: Cascade)
  createdBy          User?                @relation("IndividualCreator", fields: [createdById], references: [id])
  birthPlaceRef      Place?               @relation("IndividualBirthPlace", fields: [birthPlaceId], references: [id])
  deathPlaceRef      Place?               @relation("IndividualDeathPlace", fields: [deathPlaceId], references: [id])
  familiesAsHusband  Family[]             @relation("FamilyHusband")
  familiesAsWife     Family[]             @relation("FamilyWife")
  familyChildren     FamilyChild[]
  userTreeLinks      UserTreeLink[]
  workspaceInvitations WorkspaceInvitation[]
  shareTokensAsRoot  BranchShareToken[]
  pointersAsRoot      BranchPointer[]       @relation("PointerRoot")
  pointersAsSelected  BranchPointer[]       @relation("PointerSelected")
  pointersAsAnchor    BranchPointer[]       @relation("PointerAnchor")
  radaFamiliesAsFosterFather RadaFamily[]   @relation("RadaFamilyFosterFather")
  radaFamiliesAsFosterMother RadaFamily[]   @relation("RadaFamilyFosterMother")
  radaFamilyChildren         RadaFamilyChild[]

  @@unique([treeId, gedcomId]) // gedcomId is unique within a tree
  @@map("individuals")
}

model Family {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  treeId    String  @map("tree_id") @db.Uuid
  gedcomId  String? @map("gedcom_id") // original GEDCOM ID if imported
  husbandId String? @map("husband_id") @db.Uuid
  wifeId    String? @map("wife_id") @db.Uuid

  // Phase 10b: event detail fields below are AES-256-GCM ciphertext
  // (nonce || tag || data) produced by src/lib/tree/encryption.ts.
  // PlaceId FKs stay plaintext so Prisma can maintain referential integrity.

  // Marriage contract (MARC)
  marriageContractDate        Bytes?  @map("marriage_contract_date")
  marriageContractHijriDate   Bytes?  @map("marriage_contract_hijri_date")
  marriageContractPlace       Bytes?  @map("marriage_contract_place")
  marriageContractPlaceId     String? @map("marriage_contract_place_id") @db.Uuid
  marriageContractDescription Bytes?  @map("marriage_contract_description")
  marriageContractNotes       Bytes?  @map("marriage_contract_notes")

  // Marriage (MARR)
  marriageDate        Bytes?  @map("marriage_date")
  marriageHijriDate   Bytes?  @map("marriage_hijri_date")
  marriagePlace       Bytes?  @map("marriage_place")
  marriagePlaceId     String? @map("marriage_place_id") @db.Uuid
  marriageDescription Bytes?  @map("marriage_description")
  marriageNotes       Bytes?  @map("marriage_notes")

  // Umm walad
  isUmmWalad           Boolean @default(false) @map("is_umm_walad")

  // Divorce (DIV)
  isDivorced           Boolean @default(false) @map("is_divorced")
  divorceDate          Bytes?  @map("divorce_date")
  divorceHijriDate     Bytes?  @map("divorce_hijri_date")
  divorcePlace         Bytes?  @map("divorce_place")
  divorcePlaceId       String? @map("divorce_place_id") @db.Uuid
  divorceDescription   Bytes?  @map("divorce_description")
  divorceNotes         Bytes?  @map("divorce_notes")

  // Relations
  tree                     FamilyTree    @relation(fields: [treeId], references: [id], onDelete: Cascade)
  husband                  Individual?   @relation("FamilyHusband", fields: [husbandId], references: [id])
  wife                     Individual?   @relation("FamilyWife", fields: [wifeId], references: [id])
  marriageContractPlaceRef Place?        @relation("FamilyMarriageContractPlace", fields: [marriageContractPlaceId], references: [id])
  marriagePlaceRef         Place?        @relation("FamilyMarriagePlace", fields: [marriagePlaceId], references: [id])
  divorcePlaceRef          Place?        @relation("FamilyDivorcePlace", fields: [divorcePlaceId], references: [id])
  children                 FamilyChild[]

  @@unique([treeId, gedcomId])
  @@map("families")
}

model FamilyChild {
  familyId     String @map("family_id") @db.Uuid
  individualId String @map("individual_id") @db.Uuid

  // Relations
  family     Family     @relation(fields: [familyId], references: [id], onDelete: Cascade)
  individual Individual @relation(fields: [individualId], references: [id], onDelete: Cascade)

  @@id([familyId, individualId])
  @@map("family_children")
}

model RadaFamily {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  treeId          String   @map("tree_id") @db.Uuid
  gedcomId        String?  @map("gedcom_id")
  fosterFatherId  String?  @map("foster_father_id") @db.Uuid
  fosterMotherId  String?  @map("foster_mother_id") @db.Uuid
  // Phase 10b: encrypted with the workspace data key
  notes           Bytes?
  createdAt       DateTime @default(now()) @map("created_at")

  tree          FamilyTree       @relation(fields: [treeId], references: [id], onDelete: Cascade)
  fosterFather  Individual?      @relation("RadaFamilyFosterFather", fields: [fosterFatherId], references: [id])
  fosterMother  Individual?      @relation("RadaFamilyFosterMother", fields: [fosterMotherId], references: [id])
  children      RadaFamilyChild[]

  @@unique([treeId, gedcomId])
  @@map("rada_families")
}

model RadaFamilyChild {
  radaFamilyId String @map("rada_family_id") @db.Uuid
  individualId String @map("individual_id") @db.Uuid

  radaFamily RadaFamily @relation(fields: [radaFamilyId], references: [id], onDelete: Cascade)
  individual Individual @relation(fields: [individualId], references: [id], onDelete: Cascade)

  @@id([radaFamilyId, individualId])
  @@map("rada_family_children")
}

// =============================================================================
// Tree Edit Log (audit trail)
// =============================================================================

model TreeEditLog {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  treeId          String   @map("tree_id") @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  action          String   // create, update, delete, cascade_delete, MOVE_SUBTREE, etc.
  entityType      String   @map("entity_type") // individual, family, family_child, rada_family, etc.
  entityId        String   @map("entity_id") @db.Uuid
  // Phase 10b follow-up (task #20): payload is AES-256-GCM ciphertext
  // encoding JSON bytes. Some payloads (e.g. cascade_delete.targetName)
  // historically carried plaintext PII; encrypting the whole JSON blob
  // closes that leak. Legacy rows written before this migration contain
  // UTF-8 bytes of the canonical JSON text — the migration script (#24)
  // detects them via the same "try decrypt first, else treat as plaintext"
  // gate used in #16 and re-encrypts in place.
  payload         Bytes?
  // Phase 10b: snapshots are JSON-serialized envelopes of the form
  // `{ _encrypted: true, data: "<base64-ciphertext>" }` when written by
  // src/lib/tree/encryption.ts. Legacy rows without the envelope remain
  // readable as plaintext (pass-through in decryptSnapshot).
  snapshotBefore  Json?    @map("snapshot_before")  // full entity state before mutation
  snapshotAfter   Json?    @map("snapshot_after")   // full entity state after mutation
  // Phase 10b follow-up (task #20): description is AES-256-GCM ciphertext.
  // Same plaintext→UTF-8-bytes migration path as payload above; #24 flips
  // each row once then stays idempotent on subsequent runs.
  description     Bytes?                             // human-readable Arabic description (ciphertext)
  timestamp       DateTime @default(now())

  // Relations
  tree FamilyTree @relation(fields: [treeId], references: [id], onDelete: Cascade)
  user User       @relation(fields: [userId], references: [id])

  @@index([treeId, timestamp])
  @@index([treeId, entityType, entityId])
  @@map("tree_edit_logs")
}

// =============================================================================
// Content: News Posts
// =============================================================================

model Post {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId    String   @map("workspace_id") @db.Uuid
  authorId       String   @map("author_id") @db.Uuid
  content        String
  mediaSizeBytes BigInt   @default(0) @map("media_size_bytes")
  isPinned       Boolean  @default(false) @map("is_pinned")
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  author    User      @relation(fields: [authorId], references: [id])

  @@index([workspaceId, createdAt])
  @@map("posts")
}

// =============================================================================
// Content: Albums
// =============================================================================

model Album {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  name        String
  createdById String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User         @relation(fields: [createdById], references: [id])
  media     AlbumMedia[]

  @@map("albums")
}

model AlbumMedia {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  albumId       String   @map("album_id") @db.Uuid
  fileUrl       String   @map("file_url")
  fileSizeBytes BigInt   @map("file_size_bytes")
  taggedIndividualIds String[] @map("tagged_individual_ids") @db.Uuid
  uploadedById  String   @map("uploaded_by") @db.Uuid
  uploadedAt    DateTime @default(now()) @map("uploaded_at")

  // Relations
  album      Album @relation(fields: [albumId], references: [id], onDelete: Cascade)
  uploadedBy User  @relation(fields: [uploadedById], references: [id])

  @@map("album_media")
}

// =============================================================================
// Content: Events
// =============================================================================

enum RsvpVisibility {
  all
  counts
  admin
}

model Event {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String         @map("workspace_id") @db.Uuid
  title       String
  startAt     DateTime       @map("start_at")
  endAt       DateTime?      @map("end_at")
  location    String?
  description String?
  isGenerated Boolean        @default(false) @map("is_generated")
  rsvpVisibility RsvpVisibility @default(all) @map("rsvp_visibility")
  createdById String         @map("created_by") @db.Uuid
  createdAt   DateTime       @default(now()) @map("created_at")

  // Relations
  workspace Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User        @relation(fields: [createdById], references: [id])
  rsvps     EventRsvp[]

  @@map("events")
}

enum RsvpStatus {
  attending
  not_attending
  maybe
}

model EventRsvp {
  userId   String     @map("user_id") @db.Uuid
  eventId  String     @map("event_id") @db.Uuid
  status   RsvpStatus
  updatedAt DateTime  @updatedAt @map("updated_at")

  // Relations
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@id([userId, eventId])
  @@map("event_rsvps")
}

// =============================================================================
// Notifications
// =============================================================================

model Notification {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   // workspace_invite, branch_invite, tree_link_request, etc.
  payload   Json?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

// =============================================================================
// Branch Share Tokens — tokens for sharing a subtree with another workspace
// =============================================================================

model BranchShareToken {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tokenHash           String    @unique @map("token_hash") // sha256 of the actual token
  sourceWorkspaceId   String    @map("source_workspace_id") @db.Uuid
  rootIndividualId    String    @map("root_individual_id") @db.Uuid
  depthLimit          Int?      @map("depth_limit") // null = unlimited
  includeGrafts       Boolean   @default(false) @map("include_grafts")
  targetWorkspaceId   String?   @map("target_workspace_id") @db.Uuid // null = public token
  isPublic            Boolean   @default(false) @map("is_public")
  maxUses             Int       @default(1) @map("max_uses")
  useCount            Int       @default(0) @map("use_count")
  isRevoked           Boolean   @default(false) @map("is_revoked")
  expiresAt           DateTime  @map("expires_at")
  createdById         String    @map("created_by") @db.Uuid
  createdAt           DateTime  @default(now()) @map("created_at")

  // Relations
  sourceWorkspace  Workspace   @relation("ShareTokenSource", fields: [sourceWorkspaceId], references: [id], onDelete: Cascade)
  targetWorkspace  Workspace?  @relation("ShareTokenTarget", fields: [targetWorkspaceId], references: [id])
  rootIndividual   Individual  @relation(fields: [rootIndividualId], references: [id])
  createdBy        User        @relation(fields: [createdById], references: [id])
  pointers         BranchPointer[]

  @@index([sourceWorkspaceId])
  @@index([targetWorkspaceId])
  @@map("branch_share_tokens")
}

// =============================================================================
// Branch Pointers — live link from source subtree to target tree
// =============================================================================

enum BranchPointerStatus {
  active
  revoked
  broken
}

enum BranchPointerRelationship {
  child
  sibling
  spouse
  parent
}

model BranchPointer {
  id                  String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sourceWorkspaceId   String                    @map("source_workspace_id") @db.Uuid
  rootIndividualId       String                    @map("root_individual_id") @db.Uuid
  selectedIndividualId   String                    @map("selected_individual_id") @db.Uuid
  depthLimit             Int?                      @map("depth_limit")
  includeGrafts          Boolean                   @default(false) @map("include_grafts")
  targetWorkspaceId      String                    @map("target_workspace_id") @db.Uuid
  anchorIndividualId     String                    @map("anchor_individual_id") @db.Uuid
  relationship        BranchPointerRelationship
  status              BranchPointerStatus       @default(active)
  linkChildrenToAnchor Boolean                  @default(false) @map("link_children_to_anchor")
  shareTokenId        String?                   @map("share_token_id") @db.Uuid // token used to create this pointer
  createdById         String                    @map("created_by") @db.Uuid
  createdAt           DateTime                  @default(now()) @map("created_at")

  // Relations
  sourceWorkspace  Workspace   @relation("PointerSource", fields: [sourceWorkspaceId], references: [id])
  targetWorkspace  Workspace   @relation("PointerTarget", fields: [targetWorkspaceId], references: [id], onDelete: Cascade)
  rootIndividual      Individual  @relation("PointerRoot", fields: [rootIndividualId], references: [id])
  selectedIndividual  Individual  @relation("PointerSelected", fields: [selectedIndividualId], references: [id])
  anchorIndividual    Individual  @relation("PointerAnchor", fields: [anchorIndividualId], references: [id])
  shareToken       BranchShareToken? @relation(fields: [shareTokenId], references: [id])
  createdBy        User        @relation(fields: [createdById], references: [id])

  @@index([targetWorkspaceId, status])
  @@index([sourceWorkspaceId])
  @@index([rootIndividualId])
  @@map("branch_pointers")
}

// =============================================================================
// Places — hierarchical location data for autocomplete
// =============================================================================

// Phase 10b note: Place.nameAr / nameEn are intentionally LEFT AS PLAINTEXT.
// Global seeded places (workspaceId IS NULL) are publicly known geography with
// no privacy value. Workspace-custom rows (workspaceId NOT NULL) are a tiny
// fraction of all places, so conflating two encoding schemes in one column
// would add complexity with marginal security benefit. If this trade-off is
// ever revisited, encrypt only rows where workspaceId IS NOT NULL.
model Place {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String?   @map("workspace_id") @db.Uuid // null = global/seeded place
  nameAr      String    @map("name_ar")
  nameEn      String?   @map("name_en")
  parentId    String?   @map("parent_id") @db.Uuid
  latitude    Float?
  longitude   Float?
  createdAt   DateTime  @default(now()) @map("created_at")

  // Relations
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent    Place?     @relation("PlaceHierarchy", fields: [parentId], references: [id])
  children  Place[]    @relation("PlaceHierarchy")

  // Reverse relations for FK references
  individualsBirthPlace         Individual[] @relation("IndividualBirthPlace")
  individualsDeathPlace         Individual[] @relation("IndividualDeathPlace")
  familiesMarriageContractPlace Family[]     @relation("FamilyMarriageContractPlace")
  familiesMarriagePlace         Family[]     @relation("FamilyMarriagePlace")
  familiesDivorcePlace          Family[]     @relation("FamilyDivorcePlace")

  @@unique([workspaceId, nameAr])
  @@map("places")
}

// =============================================================================
// Admin Access Log — Phase 10b operational safeguard
// Captures any server-side / admin access to workspace data outside normal
// authenticated member requests. Helper at src/lib/audit/admin-access.ts.
// Scaffold + helper only — wiring to admin routes lives in a future phase.
// =============================================================================

model AdminAccessLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // Phase 10b security review (T9 MEDIUM-1): NO FK relation to User. The
  // audit log must be IMMORTAL across user deletion — a deleted user's
  // access history is exactly what we need most. Keeping `userId` as a raw
  // UUID column with no `@relation` removes the cascade and the include type.
  userId      String   @map("user_id") @db.Uuid
  action      String   @db.VarChar(100) // 'workspace_data_read' | 'audit_log_read' | 'cascade_delete_preview' | etc.
  workspaceId String?  @map("workspace_id") @db.Uuid
  entityType  String?  @map("entity_type") @db.VarChar(100)
  entityId    String?  @map("entity_id") @db.VarChar(100)
  reason      String?  @db.VarChar(500)
  // T9 MEDIUM-2: cap ipAddress at 64 chars so a caller passing X-Forwarded-For
  // verbatim cannot flood the table with megabyte values.
  ipAddress   String?  @map("ip_address") @db.VarChar(64)
  userAgent   String?  @map("user_agent") @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at")

  // Workspace relation kept (workspaces are intentional admin actions, not
  // stealth-cleanup paths) but with SetNull so audit rows survive workspace
  // deletion as well.
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([workspaceId, createdAt])
  @@index([action, createdAt])
  @@map("admin_access_logs")
}
