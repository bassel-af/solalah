# =============================================================================
# Gynat Environment Variables
# Copy this file to .env.local and fill in the values
# =============================================================================

# --- Supabase (self-hosted) ---
# These match the Docker Compose services in docker/docker-compose.yml

# PostgreSQL (used by Prisma)
DATABASE_URL="postgresql://postgres:your-super-secret-password@localhost:5432/gynat?schema=public"

# Supabase API URL (Kong gateway)
NEXT_PUBLIC_SUPABASE_URL="http://localhost:8000"

# Supabase anon key (public, safe for browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Supabase service role key (server-side only, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# JWT secret (shared between GoTrue and your app for token verification)
SUPABASE_JWT_SECRET="your-jwt-secret-at-least-32-characters-long"

# --- GoTrue (Auth) ---
GOTRUE_SITE_URL="http://localhost:4000"
GOTRUE_URI_ALLOW_LIST="http://localhost:4000/**"

# --- Google OAuth (optional, leave empty to disable) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- SMTP (for email invitations and auth emails) ---
# For local dev, point at the bundled Mailpit container:
#   SMTP_HOST=127.0.0.1
#   SMTP_PORT=1125
# Then view captured mail at http://localhost:8125
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_SENDER_EMAIL="noreply@gynat.com"
SMTP_SENDER_NAME="جينات"

# --- Mailpit (test mail trap — see docs/testing.md) ---
# HTTP API URL used by the e2e test helpers (pnpm test:e2e).
MAILPIT_API_URL="http://localhost:8125"

# --- Site URL (used for invite links) ---
NEXT_PUBLIC_SITE_URL="http://localhost:4000"

# --- Workspace Encryption (Phase 10b Layer 2) ---
# Base64-encoded 32-byte AES-256 master key used to wrap per-workspace data
# encryption keys. Required at server startup — the app will fail fast if
# missing or malformed. Never commit this value; store backups securely.
# Losing this key makes ALL workspace data unrecoverable.
# Generate with: openssl rand -base64 32
WORKSPACE_MASTER_KEY=
